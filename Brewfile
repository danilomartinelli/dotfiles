# Homebrew Settings
cask_args appdir: "/Applications", require_sha: true
tap "homebrew/bundle" # Support for managing packages via Brewfile
tap "homebrew/services" # Manage system services with Homebrew

# Terminal and Shell Tools
brew "bash" # Popular and flexible shell
brew "coreutils" # GNU utilities (ls, cat, etc.)
brew "findutils" # Advanced GNU find, locate, xargs, and updatedb
brew "grep" # GNU grep, a powerful text search tool
brew "gnu-sed" # GNU sed for stream editing
brew "gnu-tar" # GNU tar for file archiving
brew "jq" # JSON processor for the command line
brew "micro" # A modern and intuitive terminal-based text editor
brew "starship" # Customizable and fast shell prompt
brew "zsh" # Modern shell
brew "zsh-completions" # Additional autocompletions for Zsh
brew "zsh-syntax-highlighting" # Syntax highlighting for Zsh

# Development Tools
brew "git" # Version control system
brew "git-lfs" # Git extension for managing large files
brew "gnupg" # OpenPGP encryption tool
brew "httpie" # User-friendly HTTP client for APIs
brew "mise" # Polyglot runtime manager (asdf rust clone)
brew "openssh" # Secure remote login and file transfer
brew "rclone" # Command-line cloud storage management
brew "taplo" # TOML configuration file formatter

# Media Tools
brew "ffmpeg" # Multimedia framework for video/audio processing
brew "media-info" # Display technical details of media files
brew "mkvtoolnix" # Tools for working with MKV video files
brew "mp4v2" # Tools for working with MP4 video files

# macOS Utilities
brew "macos-trash" if OS.mac? # Safe trash utility for macOS
brew "mas" if OS.mac? # Command-line interface for Mac App Store
brew "pinentry-mac" if OS.mac? # Secure password entry for macOS GPG

# GUI Applications (via Cask)
cask "arc" # Arc browser
cask "apidog" # API testing tool
cask "datagrip" # Database management IDE
cask "font-recursive-code" # Recursive Code font
cask "franz" # Multi-messenger platform
cask "fleet" # Advanced Text Editor
cask "karabiner-elements" # Advanced keyboard remapping tool
cask "kitty" # Lightweight terminal emulator
cask "notion" # Productivity and note-taking app
cask "orbstack" # Lightweight alternative for Docker and Linux VMs
cask "protonvpn" # Secure VPN service
cask "webstorm" # IDE for JavaScript and web development

# Mac App Store Applications
mas "calendars", id: 608834326 # Calendar management tool
mas "paste", id: 967805235 # Clipboard history manager
mas "pdf expert", id: 1055273043 # PDF editor and reader
mas "spark", id: 6445813049 # Email client
mas "testflight", id: 899247664 # App testing platform
